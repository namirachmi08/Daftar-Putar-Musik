<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>Moodify</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:#121212;
    color:white;
}

.container{
    display:flex;
    height:calc(100vh - 120px);
}

.sidebar{
    width:200px;
    padding:10px;
    background:#000;
    overflow-y:auto;
}

input[type="file"]{
    width:100%;
    font-size:12px;
    color:white;
}

.folder-item{
    list-style:none;
    padding:8px;
    cursor:pointer;
    border-radius:6px;
}

.folder-item:hover{ background:#222; }
.folder-item.active{ background:#1db954; }

.main{
    flex:1;
    padding:15px;
    overflow-y:auto;
}

li{
    list-style:none;
    padding:8px;
    cursor:pointer;
    border-radius:6px;
}

li:hover{ background:#222; }

.now{
    color:#1db954;
    font-weight:bold;
}

.player{
    position:fixed;
    bottom:0;
    width:100%;
    background:#181818;
    padding:12px 10px;
    text-align:center;
}

#now{
    margin-bottom:6px;
    font-size:14px;
}

#time{
    font-size:12px;
    color:#b3b3b3;
    margin-top:4px;
    margin-bottom:8px;
}

.progress{
    width:70%;
    height:5px;
    background:#333;
    margin:10px auto;
    border-radius:10px;
    overflow:hidden;
}

.progress-bar{
    height:100%;
    background:#1db954;
    width:0%;
}

.controls button{
    background:none;
    border:none;
    color:white;
    font-size:16px;
    cursor:pointer;
    margin:4px;
    padding:4px;
}

.controls button:hover{ color:#1db954; }

.credit{
    position:absolute;
    bottom:10px;
    left:15px;
    font-size:11px;
    color:#535353;
}
</style>
</head>

<body>

<div class="container">

    <div class="sidebar">
        <h3>Daftar Putar</h3>
        <input type="file" id="fileInput" webkitdirectory multiple>
        <ul id="playlistFolders"></ul>
    </div>

    <div class="main">
        <h3>🎧 Musik</h3>
        <ul id="playlist"></ul>
    </div>
</div>

<div class="player">

    <div id="now">Belum ada lagu</div>
    <div id="time">00:00 / 00:00</div>

    <div class="progress">
        <div class="progress-bar" id="progressBar"></div>
    </div>

    <div class="controls">
        <button onclick="prevSong()">⏮</button>
        <button onclick="playSong()">▶</button>
        <button onclick="pauseSong()">⏸</button>
        <button onclick="nextSong()">⏭</button>
    </div>

    <div class="credit">Made by Nami & Astia</div>

</div>

<script>

let playlists    = {};
let songs        = [];
let activeFolder = null;
let currentIndex = 0;
let currentSong  = null;

const audio      = new Audio();
const fileInput  = document.getElementById("fileInput");
const folderEl   = document.getElementById("playlistFolders");
const playlistEl = document.getElementById("playlist");
const bar        = document.getElementById("progressBar");
const time       = document.getElementById("time");

fileInput.addEventListener("change", e => {
    const files = [...e.target.files].filter(
        f => f.name.toLowerCase().endsWith(".mp3")
    );

    files.forEach(f => {
        const folder = f.webkitRelativePath.split("/").slice(-2)[0];
        if (!playlists[folder]) playlists[folder] = [];
        playlists[folder].push(f);
    });

    activeFolder = Object.keys(playlists)[0];
    songs = playlists[activeFolder];

    renderFolders();
    renderPlaylist();
    playSong();
});

function renderFolders() {
    folderEl.innerHTML = "";

    Object.keys(playlists).forEach(folder => {
        const li = document.createElement("li");
        li.className = "folder-item";
        li.textContent = "📁 " + folder;

        if (folder === activeFolder)
            li.classList.add("active");

        li.onclick = () => {
            activeFolder = folder;
            songs = playlists[folder];
            currentIndex = 0;

            renderFolders();
            renderPlaylist();
        };

        folderEl.appendChild(li);
    });
}

function renderPlaylist() {
    playlistEl.innerHTML = "";

    songs.forEach((s, i) => {
        const li = document.createElement("li");
        li.textContent = s.name.replace(".mp3", "");

        if (currentSong && s.name === currentSong.name)
            li.classList.add("now");

        li.onclick = () => {
            currentIndex = i;
            playSong();
        };

        playlistEl.appendChild(li);
    });
}

function playSong() {
    if (!songs.length) return;

    const selected = songs[currentIndex];

    if (!currentSong || currentSong !== selected) {
        currentSong = selected;
        audio.src = URL.createObjectURL(currentSong);
        document.getElementById("now").textContent = currentSong.name;
    }

    audio.play();
    renderPlaylist();
}

function nextSong() {
    currentIndex = (currentIndex + 1) % songs.length;
    playSong();
}

function prevSong() {
    currentIndex = (currentIndex - 1 + songs.length) % songs.length;
    playSong();
}

function pauseSong() {
    audio.pause();
}

function format(t) {
    if (!t || isNaN(t)) return "00:00";
    const m = Math.floor(t / 60);
    const s = Math.floor(t % 60);
    return `${m}:${s < 10 ? "0" : ""}${s}`;
}

audio.addEventListener("timeupdate", () => {
    if (audio.duration)
        bar.style.width = (audio.currentTime / audio.duration) * 100 + "%";

    time.textContent =
        `${format(audio.currentTime)} / ${format(audio.duration)}`;
});

audio.addEventListener("ended", nextSong);

</script>

</body>
</html>
